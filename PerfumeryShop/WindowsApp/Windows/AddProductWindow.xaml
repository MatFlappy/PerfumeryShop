<Window x:Class="PerfumeryShop.WindowsApp.Windows.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
       Title="Добавление товара"
        Height="600"
        Width="550"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F1"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="16" Padding="20">
            <StackPanel>
                <TextBlock Text="Добавление товара"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#7A3E48"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Название"/>
                <TextBox x:Name="tbName" Height="34" Margin="0,5,0,10"/>

                <TextBlock Text="Описание"/>
                <TextBox x:Name="tbDescription" Height="80" Margin="0,5,0,10" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Цена"/>
                <TextBox x:Name="tbPrice" Height="34" Margin="0,5,0,10"/>

                <TextBlock Text="Категория"/>
                <ComboBox x:Name="cbCategory" Height="34" Margin="0,5,0,10"/>

                <TextBlock Text="Ссылка на изображение"/>
                <TextBox x:Name="tbImagePath" Height="34" Margin="0,5,0,10"/>

                <TextBlock Text="Используй прямую ссылку на jpg или png"
                           Foreground="Gray"
                           Margin="0,0,0,5"/>

                <Border Width="120"
                        Height="150"
                        Background="#FFF1F1"
                        CornerRadius="12"
                        HorizontalAlignment="Left"
                        ClipToBounds="True"
                        Margin="0,5,0,0">
                    <Image x:Name="imgPreview" Stretch="UniformToFill"/>
                </Border>

                <Button Content="Показать превью"
                        Width="130"
                        Height="34"
                        Margin="0,10,0,0"
                        Click="Preview_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="130" Height="36" Margin="5" Click="Save_Click"/>
            <Button Content="Отмена" Width="120" Height="36" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
