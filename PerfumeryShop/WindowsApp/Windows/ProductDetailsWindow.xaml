<Window x:Class="PerfumeryShop.WindowsApp.Windows.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
        Title="Информация о товаре"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        
        Background="#FFF6F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="18" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="210" Height="260" Background="#FFF1F1" CornerRadius="16" ClipToBounds="True">
                    <Image x:Name="imgProduct" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="25,0,0,0">
                    <TextBlock x:Name="tbName"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2D1F23"
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Описание"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#7A3E48"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="tbDescription"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="#4E4043"
                               Margin="0,0,0,15"/>

                    <Border Background="#FCE8E8" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <TextBlock x:Name="tbPrice"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#8B3A3A"/>
                    </Border>

                    <TextBlock x:Name="tbCategory"
                               FontSize="15"
                               Foreground="#5E4E52"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Совет:"
                               FontWeight="SemiBold"
                               Foreground="#7A3E48"/>

                    <TextBlock Text="Дважды проверьте товар перед оформлением заявки. В этом окне можно быстро добавить его в избранное или заказать."
                               TextWrapping="Wrap"
                               Foreground="#6A5A5E"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnFavorite" Content="В избранное" Width="140" Height="38" Margin="6" Click="btnFavorite_Click"/>
            <Button x:Name="btnOrder" Content="Оформить заявку" Width="150" Height="38" Margin="6" Click="btnOrder_Click"/>
            <Button Content="Закрыть" Width="120" Height="38" Margin="6" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
