<Window x:Class="PerfumeryShop.WindowsApp.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
       Title="Регистрация" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ФИО"/>
            <TextBox x:Name="tbFullName" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="tbLogin" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="pbPassword" Height="30" Margin="0,5,0,10"/>

            <Button Content="Зарегистрироваться" Height="35" Margin="0,10,0,0" Click="Register_Click"/>
            <Button Content="Назад" Height="35" Margin="0,10,0,0" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>
