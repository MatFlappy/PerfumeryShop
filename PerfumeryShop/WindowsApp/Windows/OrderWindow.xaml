<Window x:Class="PerfumeryShop.WindowsApp.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
       Title="Оформление заявки"
        Height="420"
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF6F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="16" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="150" Height="200" Background="#FFF1F1" CornerRadius="12" ClipToBounds="True">
                    <Image x:Name="imgProduct" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Оформление заявки"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#7A3E48"
                               Margin="0,0,0,15"/>

                    <TextBlock x:Name="tbProductName"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="tbPrice"
                               FontSize="15"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Ваш телефон"/>
                    <TextBox x:Name="tbPhone"
                             Height="32"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Комментарий"/>
                    <TextBox x:Name="tbComment"
                             Height="80"
                             Margin="0,5,0,10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Text="После оформления заявка появится у администратора."
                               Foreground="Gray"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Подтвердить" Width="140" Height="36" Margin="5" Click="Confirm_Click"/>
            <Button Content="Отмена" Width="120" Height="36" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
