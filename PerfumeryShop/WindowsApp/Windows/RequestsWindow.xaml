<Window x:Class="PerfumeryShop.WindowsApp.Windows.RequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
        Title="Список заявок"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F1">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <DockPanel>
                <TextBlock Text="Список заявок"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#7A3E48"
                           DockPanel.Dock="Left"/>

                <TextBlock x:Name="tbCount"
                           FontSize="16"
                           Foreground="Gray"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="dgRequests"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  Margin="0,0,0,10"
                  RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding UserName}" Width="180"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="170"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="Обновить" Width="120" Height="35" Margin="5" Click="Refresh_Click"/>
                    <Button Content="Удалить заявку" Width="140" Height="35" Margin="5" Click="Delete_Click"/>
                    <Button Content="Назад" Width="120" Height="35" Margin="5" Click="Back_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ComboBox x:Name="cbStatus" Width="180" Height="35" Margin="5"/>
                    <Button Content="Изменить статус" Width="150" Height="35" Margin="5" Click="ChangeStatus_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
