<Window x:Class="PerfumeryShop.WindowsApp.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerfumeryShop.WindowsApp.Windows"
        mc:Ignorable="d"
        Title="Авторизация"
        Height="470"
        Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF6F1">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="20,0,0,20" Padding="25">
            <Grid>
                <Image Stretch="UniformToFill"
                       Source="https://images.unsplash.com/photo-1541643600914-78b084683601?fm=jpg&amp;q=80&amp;w=900"/>
                <Border Background="#66FFFFFF" CornerRadius="16" Margin="10"/>
                <StackPanel VerticalAlignment="Bottom" Margin="15">
                    <TextBlock Text="Магия флакона"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#7A3E48"/>
                    <TextBlock Text="Мир ароматов, любимых композиций и стильных покупок"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="#5C4B4F"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="0,20,20,0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вход в систему"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#7A3E48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1"
                           Text="Введите логин и пароль"
                           FontSize="14"
                           Foreground="#8A6D75"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="Логин"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#5C4B4F"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="tbLogin"
                             Height="38"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,25">
                    <TextBlock Text="Пароль"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#5C4B4F"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="pbPassword"
                                 Height="38"
                                 FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Button Content="Войти"
                            Width="140"
                            Click="Login_Click"/>
                    <Button Content="Регистрация"
                            Width="160"
                            Background="#D9AAB7"
                            Click="Register_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>